# Copy to `.env` (git-ignored). NEVER commit real secrets (Hard Rule #3).

# HMAC signing key for trust attestations (dev only; P1 upgrades to Ed25519 keypair).
TRIPWIRE_SIGNING_KEY=dev-only-change-me

# Demo canary (clearly labelled, fake — see Hard Rule #4). Not a real credential.
TRIPWIRE_CANARY_SECRET=CANARY-do-not-exfiltrate-0000

# Observability (P1, Cloud Run). Leave unset for local runs.
# LOGS_BUCKET_NAME=
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT  # security tool: never log raw payloads
