# Copy to `.env` (git-ignored). NEVER commit real secrets (Hard Rule #3).

# ── Signing (trust badges) ─────────────────────────────────────────────
# Backend resolution order (RFC-0002): Ed25519 key path → HMAC key → dev key.
# HMAC-SHA256 shared secret — the default, stdlib-only backend.
TRIPWIRE_SIGNING_KEY=dev-only-change-me

# Ed25519 backend (requires `uv sync --extra signing`; keys via `tripwire key gen`).
# When set, takes precedence over TRIPWIRE_SIGNING_KEY for signing.
# TRIPWIRE_PRIVATE_KEY_PATH=/path/to/ed25519_private.pem
# Public key for verifying Ed25519 badges (e.g. as an external verifier).
# TRIPWIRE_PUBLIC_KEY_PATH=/path/to/ed25519_public.pem
# Last-resort dev fallback (labelled DEV-KEY-DO-NOT-USE-IN-PROD). Never in production.
# TRIPWIRE_ALLOW_DEV_KEY=1

# ── Demo ───────────────────────────────────────────────────────────────
# Demo canary (clearly labelled, fake — see Hard Rule #4). Not a real credential.
TRIPWIRE_CANARY_SECRET=CANARY-do-not-exfiltrate-0000

# ── HTTP gateway (optional, `[agent]` extra) ───────────────────────────
# Upstream SSE MCP server guarded by the /mcp/sse mount (RFC-0004).
# TRIPWIRE_UPSTREAM_SSE_URL=

# ── ADK live-LLM mode (optional — every demo runs WITHOUT a model key) ─
# Only needed to drive the agents with a real model (agents-cli playground,
# Cloud Run). Pick ONE route; see docs/runbooks/deploy.md.
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=True

# ── Observability (Cloud Run) ──────────────────────────────────────────
# LOGS_BUCKET_NAME=
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT  # security tool: never log raw payloads
